# ─────────────────────────────────────────────────────────────────────────────
# .env.example  –  Local development environment template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in real values for local testing.
# NEVER commit ".env" to source control – it is listed in .gitignore.
#
# In GitHub Actions these variables are supplied via repository Secrets
# (Settings → Secrets and variables → Actions) and referenced in the
# workflow yaml as  ${{ secrets.VARIABLE_NAME }}.
# ─────────────────────────────────────────────────────────────────────────────

# ── OAuth2 credentials (from Google Cloud Console → APIs & Services → Credentials)
GDRIVE_CLIENT_ID=YOUR_CLIENT_ID_HERE.apps.googleusercontent.com
GDRIVE_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE

# ── Long-lived refresh token (obtained via the offline OAuth2 consent flow)
# See README §"Obtaining a Refresh Token" for step-by-step instructions.
GDRIVE_REFRESH_TOKEN=YOUR_REFRESH_TOKEN_HERE

# ── Drive destination & file metadata
GDRIVE_FOLDER_ID=YOUR_DRIVE_FOLDER_ID_HERE
GDRIVE_FILE_NAME=my-upload.txt
GDRIVE_MIME_TYPE=text/plain

# ── Path to the local file you want to upload
UPLOAD_SOURCE_PATH=./path/to/local/file.txt
